{
  "name": "honey-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "vercel-build": "npm run build:frontend && prisma generate && tsc -p tsconfig.build.json",
    "prisma:sync": "node scripts/prisma-sync.mjs",
    "build:frontend": "npm install --prefix frontend && npm run build --prefix frontend",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "postinstall": "prisma generate",
    "typecheck": "prisma generate && tsc --noEmit",
    "typesheck": "npm run typecheck",
    "seed": "tsx prisma/seed.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "generate:qrs": "node scripts/generate-qrs.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@supabase/supabase-js": "^2.108.0",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.1",
    "qrcode": "^1.5.4",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "web-push": "^3.6.7",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.29",
    "@types/qrcode": "^1.5.6",
    "@types/web-push": "^3.6.4",
    "pdf-lib": "^1.17.1",
    "prisma": "^6.19.3",
    "sharp": "^0.34.5",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
