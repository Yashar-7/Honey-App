    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.1",
    "qrcode": "^1.5.4",
    "web-push": "^3.6.7",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.29",
    "@types/qrcode": "^1.5.6",
    "@types/web-push": "^3.6.4",
    "prisma": "^6.19.3",
