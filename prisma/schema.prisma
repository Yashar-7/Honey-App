generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  passwordHash      String             @map("password_hash")
  name              String
  phone             String?
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  pets              Pet[]
  pushSubscriptions PushSubscription[]

  @@map("users")
}

model Pet {
  id                  String           @id @default(uuid())
  userId              String           @map("user_id")
  name                String
  species             String?
  breed               String?
  photoUrl            String?          @map("photo_url")
  qrToken             String           @unique @map("qr_token")
  isActive            Boolean          @default(true) @map("is_active")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  isLost              Boolean          @default(false) @map("is_lost")
  lastLat             Float?           @map("last_lat")
  lastLng             Float?           @map("last_lng")
  age                 String?
  characteristics     String?
  finderMessage       String?          @map("finder_message")
  allergies           String?
  behavioralNotes     String?          @map("behavioral_notes")
  medicalConditions   String?          @map("medical_conditions")
  medications         String?
  color               String?
  distinguishingMarks String?          @map("distinguishing_marks")
  neighborhood        String?
  sex                 String?
  size                String?
  zipCode             String?          @map("zip_code")
  contactSessions     ContactSession[]
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  qrTokenHistory      QrTokenHistory[]
  scans               Scan[]

  @@index([userId])
  @@index([qrToken])
  @@index([neighborhood])
  @@index([zipCode])
  @@map("pets")
}

model QrTokenHistory {
  id            String   @id @default(uuid())
  petId         String   @map("pet_id")
  qrToken       String   @unique @map("qr_token")
  deactivatedAt DateTime @default(now()) @map("deactivated_at")
  pet           Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@map("qr_token_history")
}

model ContactSession {
  id                 String    @id @default(uuid())
  petId              String    @map("pet_id")
  qrToken            String    @map("qr_token")
  status             String    @default("open")
  visitorFingerprint String?   @map("visitor_fingerprint")
  expiresAt          DateTime  @map("expires_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  pet                Pet       @relation(fields: [petId], references: [id], onDelete: Cascade)
  messages           Message[]

  @@index([petId])
  @@index([petId, visitorFingerprint, status])
  @@map("contact_sessions")
}

model Message {
  id                String         @id @default(uuid())
  sessionId         String         @map("session_id")
  text              String?
  locationReference String?        @map("location_reference")
  createdAt         DateTime       @default(now()) @map("created_at")
  sender            String         @default("finder")
  imageUrl          String?        @map("image_url")
  session           ContactSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("messages")
}

model Scan {
  id        String   @id @default(uuid())
  petId     String   @map("pet_id")
  latitude  Decimal  @db.Decimal(10, 8)
  longitude Decimal  @db.Decimal(11, 8)
  accuracy  Float?
  scannedAt DateTime @default(now()) @map("scanned_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId, scannedAt(sort: Desc)])
  @@map("scans")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String   @map("p256dh_key")
  auth      String   @map("auth_key")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}