# === BASE DE DATOS (Neon) ===
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# === APP ===
PORT=3000
JWT_SECRET="genera_un_string_largo_y_aleatorio_aqui"
BASE_URL="https://tu-dominio-en-vercel.app"

# === SUPABASE (OBLIGATORIO en Vercel para chapitas + fotos + realtime) ===
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_ANON_KEY="tu-anon-key-publica"
SUPABASE_SERVICE_ROLE_KEY="solo-necesario-en-servidor-no-compartir"
SUPABASE_PET_PHOTOS_BUCKET="pet-photos"
# QR_STOCK_SOFT_FALLBACK=false  # default OFF (MVP comercial: sin registro sin stock)
# QR_STOCK_SOFT_FALLBACK=true   # solo emergencia: permite UI de registro si Supabase cae

# Tabla QrStock (chapas físicas): ejecutar supabase/migrations/20260613190000_qr_stock.sql en Supabase SQL Editor

# === GOOGLE MAPS (Geocoding inverso — servidor) ===
Maps_API_KEY="tu-api-key-de-google-maps"
# GEOCODING_DEBUG=true  # opcional: envía detalle de errores Google al navegador (dev)

# === WEB PUSH ===
VAPID_PUBLIC_KEY="tu-public-key"
VAPID_PRIVATE_KEY="tu-private-key"
VAPID_SUBJECT="mailto:tu-email@ejemplo.com"